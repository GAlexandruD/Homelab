{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "ignorePaths": ["apps/_base/**"],
  "osvVulnerabilityAlerts": true,
  "kubernetes": {
    "fileMatch": [
      "\\.yaml$"
    ]
  },
  "regexManagers": [
    {
      "description": "Flux HelmRelease chart version updates via inline renovate comments",
      "fileMatch": ["(^|/)release\\.yaml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) registryUrl=(?<registryUrl>\\S+)\\n\\s+chart: (?<depName>\\S+)\\n\\s+version: \"(?<currentValue>[^\"]+)\""
      ]
    }
  ]
}
